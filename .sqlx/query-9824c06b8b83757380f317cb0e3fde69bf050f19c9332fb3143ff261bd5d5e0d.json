{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            fi.id,\n            fi.type as \"item_type!\",\n            fi.brand,\n            fi.name,\n            fi.quantity,\n            fi.unit,\n            fi.price,\n            fi.expiration_date,\n            fi.purchase_date,\n            fi.notes,\n            fi.location_id,\n            fi.active,\n            fi.consumed_at,\n            fi.created_at,\n            fi.updated_at\n        FROM food_items fi\n        INNER JOIN trip_items ti ON fi.id = ti.food_item_id\n        WHERE ti.trip_id = $1\n        ORDER BY fi.name\n        ",
